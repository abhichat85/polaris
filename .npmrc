# Hoist all packages to root node_modules (npm-compatible layout).
# Required because Turbopack identifies modules by file path — pnpm's virtual
# store creates two distinct paths for the same package (root real-dir vs
# .pnpm/… virtual-store), causing CodeMirror's instanceof checks to fail:
#   "Unrecognized extension value … multiple instances of @codemirror/state"
shamefully-hoist=true
